;; ShiftLefter configuration
;; Copy to shiftlefter.edn and customize

{:parser {:dialect "en"}       ;; Language dialect (en, fr, de, etc.)

 :runner {:step-paths ["steps/"]      ;; Where to find step definitions
          :allow-pending? false}      ;; Exit 0 even with pending steps?

 ;; --- Shifted mode (the advertised path) ---
 ;; Uncomment to validate scenarios against a project glossary at planning
 ;; time, before anything runs. The presence of :svo enables Shifted mode;
 ;; `sl orient` confirms which mode you're in. See docs/SVO.md for the
 ;; glossary file formats.
 ;;
